//npx prisma db push


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL") // Store DB credentials in .env
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(PASSENGER) // Default role is Passenger
  createdAt DateTime @default(now())
  tickets   Ticket[] // Relation to tickets
}

model Bus {
  id        String   @id @default(uuid())
  busName   String
  capacity  Int
  type      BusType  @default(REGULAR)
  createdAt DateTime @default(now())
  routes    Route[]  // Relation to routes
  tickets   Ticket[] // Relation to tickets
}

model Route {
  id          String   @id @default(uuid())
  source      String
  destination String
  distance    Float    // Distance in kilometers
  busId       String
  bus         Bus      @relation(fields: [busId], references: [id])
  tickets     Ticket[] // Relation to tickets
  createdAt   DateTime @default(now())
}

model Ticket {
  id        String      @id @default(uuid())
  passengerId String
  passenger   User       @relation(fields: [passengerId], references: [id])
  busId      String
  bus        Bus        @relation(fields: [busId], references: [id])
  routeId    String
  route      Route      @relation(fields: [routeId], references: [id])
  price      Float
  status     TicketStatus @default(PENDING)
  createdAt  DateTime    @default(now())
}

enum Role {
  ADMIN
  DRIVER
  PASSENGER
}

enum BusType {
  REGULAR
  LUXURY
  EXPRESS
}

enum TicketStatus {
  PENDING
  CONFIRMED
  CANCELLED
}
